# Copy this file to .env and fill in the values from your Supabase project
# (Project Settings > API). .env is already gitignored — never commit real keys.

# Used by the app (src/lib/supabase.ts) — safe to expose to the client —
# and also picked up by scripts/*.mjs (no need to duplicate the values).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Used only by scripts/seed-supabase.mjs and scripts/test-supabase-connection.mjs
# (never used in app code, never shipped to the client). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=
